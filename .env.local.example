# App
NEXT_PUBLIC_APP_NAME=Yummy Kingdom
NEXT_PUBLIC_APP_DESCRIPTION=We deliver a wide range of Delicious Italian food with the Hidden secrets in the kingdom.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Auth.js
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3000

# Database (PostgreSQL / Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Payments (optional for local development if not testing payments now)
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_APP_SECRET=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# UploadThing (optional)
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# App behavior
PAYMENT_METHODS=CashOnDelivery, Stripe, PayPal
DEFAULT_PAYMENT_METHOD=CashOnDelivery
PAGE_SIZE=6
LATEST_PRODUCTS_LIMIT=4
